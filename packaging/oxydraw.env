# oxydraw configuration (read by the systemd unit via EnvironmentFile=).
# This is a dpkg conf-file: your edits are preserved across package upgrades.
# Restart after editing:  sudo systemctl restart oxydraw

# --- network ---------------------------------------------------------------
# Bind address. Put oxydraw behind a TLS-terminating reverse proxy and
# bind to localhost; expose 3002 directly only for testing.
LISTEN=127.0.0.1:3002

# --- storage ---------------------------------------------------------------
# sqlite (default, embedded) | memory (volatile, dev/tests only).
STORAGE_TYPE=sqlite

# SQLite: an absolute path inside the systemd StateDirectory.
DATA_SOURCE_NAME=/var/lib/oxydraw/oxydraw.db

# --- frontend --------------------------------------------------------------
# Public host injected into served assets when behind a reverse proxy / custom
# domain (no scheme, just the host[:port]).
# EXCALIDRAW_BACKEND_HOST=draw.example.com

# Log verbosity (tracing env-filter syntax).
RUST_LOG=info
