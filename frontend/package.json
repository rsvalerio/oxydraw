{
  "name": "oxydraw-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "OxyDraw frontend — a custom SPA built on the @excalidraw/excalidraw editor component.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^2.2.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
