# Build artifacts
/backend/target/

# .deb packaging build output (staging tree + .deb; regenerated by `make` in
# packaging/deb). Never commit: the binary embeds the bundled frontend and trips
# secret scanners on Excalidraw's public Firebase web key.
/packaging/deb/.build/

# Stale local checkout of upstream excalidraw (now fetched as a pinned tarball in the
# Dockerfile frontend stage; see `make frontend`).
/excalidraw/

# Environment
.env
.env.*
# ...but keep the committed template.
!.env.example

# Embedded frontend build output (populated at build time; see `make frontend`).
# Only the .gitkeep is tracked so the dir exists for rust-embed; built assets are never committed.
/backend/crates/server/assets/*
!/backend/crates/server/assets/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# local database (holds user data incl. scene AES keys - never commit), with SQLite
# -wal/-shm sidecars
*.db
*.db-wal
*.db-shm

# Local task backlog (internal code-review findings; not part of the public repo)
/backlog/

# OS
.DS_Store
Thumbs.db

# Coverage
*.profraw
