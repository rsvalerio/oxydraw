# oxydraw configuration. Copy to `.env` and adjust; all values are read from the
# environment, so these can also be set directly (e.g. in Docker / systemd).

# Bind address.
LISTEN=0.0.0.0:3002

# Storage backend: sqlite (default, embedded) | memory (volatile, dev/tests).
STORAGE_TYPE=sqlite

# SQLite path or sqlite: URL (default: oxydraw.db in the working directory).
# DATA_SOURCE_NAME=/var/lib/oxydraw/oxydraw.db

# Origins allowed to call the API cross-origin (comma-separated, with scheme). Unset
# (default): no CORS headers - same-origin only, which the bundled UI needs anyway.
# The literal * allows everything; development only.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://tool.example

# Total-size ceilings (bytes) for anonymously writable durable data; once reached, new
# writes are rejected with 507. Defaults: 1 GiB each.
# MAX_DOCUMENTS_BYTES=1073741824   # shared documents (export-to-link blobs)
# MAX_FILES_BYTES=1073741824       # saved scenes' image files (files/shareLinks/*)

# Row-count ceiling for saved scenes' image files; bounds the durable table even when
# payloads are tiny and the byte ceiling never trips. Default: 100000.
# MAX_FILES_COUNT=100000

# --- Scene library authentication (docs/AUTH.md). All unset = library stays open. ---

# Shared-password login for the overlay's scene library.
# EXT_PASSWORD=change-me

# Public base URL (with scheme), used to build OAuth redirect URIs.
# PUBLIC_URL=https://oxydraw.example.com

# "Sign in with Google" (Google Cloud Console → Credentials → OAuth client ID).
# Redirect URI: ${PUBLIC_URL}/api/ext/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# "Sign in with GitHub" (github.com → Settings → Developer settings → OAuth Apps).
# Callback URL: ${PUBLIC_URL}/api/ext/auth/callback/github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
